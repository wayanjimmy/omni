{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "OMNI: Build",
            "type": "shell",
            "command": "cargo build 2>&1 | omni",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": [
                "$rustc"
            ]
        },
        {
            "label": "OMNI: Test",
            "type": "shell",
            "command": "cargo test 2>&1 | omni",
            "group": {
                "kind": "test",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always"
            }
        },
        {
            "label": "OMNI: Stats",
            "type": "shell",
            "command": "omni stats",
            "group": "none",
            "presentation": {
                "reveal": "always",
                "panel": "dedicated"
            }
        }
    ]
}