{
    "name": "omni-signal-engine",
    "version": "0.1.0",
    "description": "OMNI intelligent output distillation for Antigravity IDE",
    "author": "OMNI Team",
    "type": "mcp",
    "mcp": {
        "transport": "stdio",
        "command": "omni",
        "args": [
            "mcp"
        ],
        "env": {
            "OMNI_AGENT": "antigravity"
        }
    },
    "tools": [
        "omni_retrieve",
        "omni_learn",
        "omni_density",
        "omni_compress"
    ],
    "hooks": {
        "postToolUse": true,
        "sessionStart": true,
        "preCompact": true
    },
    "homepage": "https://github.com/fajarhide/omni"
}